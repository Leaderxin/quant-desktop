{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quant-desktop",
  "version": "1.0.0",
  "identifier": "com.ly-xuzhix.quant-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuantDesktop",
        "width": 1388,
        "height": 1009,
        "visible": false,
        "center": true,
        "decorations": true,
        "resizable": true
      },
      {
        "label": "ticker",
        "title": "QuantDesktop Ticker",
        "url": "ticker.html",
        "width": 230,
        "height": 38,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": true,
        "resizable": false,
        "focus": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
