{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "ticker"],
  "permissions": [
    "core:default",
    "opener:default",
    "autostart:default",
    "core:window:allow-set-position",
    "core:window:allow-outer-position",
    "core:window:allow-scale-factor"
  ]
}
