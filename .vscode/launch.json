{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Tauri Dev (Full App)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "tauri", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "🔍 Debug Rust Backend (Windows MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/src-tauri/target/debug/quant-desktop.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "cargo: build dev"
    },
    {
      "name": "🔍 Debug Rust Backend (macOS/Linux LLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/src-tauri/target/debug/quant-desktop",
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"],
      "preLaunchTask": "cargo: build dev"
    },
    {
      "name": "🪟 Chrome: Frontend Dev (localhost:3000)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/*"
      },
      "preLaunchTask": "vite: dev server"
    },
    {
      "name": "🪟 Edge: Frontend Dev (localhost:3000)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/*"
      },
      "preLaunchTask": "vite: dev server"
    },
    {
      "name": "🎨 Vite Dev Server Only",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "⚡ Full Debug (Vite + Rust)",
      "configurations": [
        "🎨 Vite Dev Server Only",
        "🔍 Debug Rust Backend (Windows MSVC)"
      ],
      "stopAll": true
    }
  ]
}
